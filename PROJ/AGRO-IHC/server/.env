# Variables de Entorno - Backend AgroFeria

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=12345
DB_NAME=agroferia_db

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=agroferia_secret_key_2025_change_in_production
JWT_EXPIRES_IN=1d
JWT_REMEMBER_EXPIRES_IN=30d

# Security
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=15

# CORS
CORS_ORIGIN=http://localhost:5173
